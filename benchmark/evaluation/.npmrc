# Block packages younger than 30 days to reduce supply-chain risk.
# Value is in minutes (pnpm 10+).
minimum-release-age=43200

# This project is intentionally isolated from the parent repo's workspace.
ignore-workspace=true
shared-workspace-lockfile=false

# Standard hygiene.
auto-install-peers=true
strict-peer-dependencies=false
save-exact=false
save-prefix=^
